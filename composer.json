{
    "name": "ocolin/plume",
    "description": "PHP client for the Plume Design ISP cloud API. Enables ISPs and CSPs to provision and manage HomePass and WorkPass subscribers via the Plume Cloud REST API.",
    "homepage": "https://github.com/ocolin/Plume",
    "keywords": [
        "plume",
        "plume-design",
        "isp",
        "csp",
        "homepass",
        "workpass",
        "wifi",
        "api-client",
        "rest",
        "opensync"
    ],
    "require": {
        "php": "^8.2",
        "psr/http-message": "^1.0|^2.0",
        "guzzlehttp/guzzle": "^7.10",
        "ocolin/global-type": "^2.0"

    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "ocolin/easyenv": "^3.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ocolin\\Plume\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ocolin\\Plume\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Colin Miller",
            "email": "ocolin@cruzio.com"
        }
    ],
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage --display-deprecations --display-notices",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html coverage"
    }
}
